# 1. Install Required Software
sudo apt update
sudo apt install openjdk-17-jdk -y
sudo apt install git -y
sudo apt install python3 python3-pip -y

# 2. Verify Installation
java -version
git --version
python3 --version
pip3 --version

# 3. Download and Run Jenkins
wget https://get.jenkins.io/war-stable/latest/jenkins.war
java -jar jenkins.war

# 4. Get Jenkins Admin Password
cat ~/.jenkins/secrets/initialAdminPassword

# 5. Create Project
mkdir AI-CI-Project
cd AI-CI-Project
touch app.py test_app.py requirements.txt Jenkinsfile

# 6. Edit Files
nano app.py
nano test_app.py
nano requirements.txt
nano Jenkinsfile

# 7. Initialize Git
git init
git add .
git commit -m "Initial CI project"

# 8. Connect GitHub
git remote add origin https://github.com/YOUR_USERNAME/AI-CI-Project.git
git branch -M main
git push -u origin main
